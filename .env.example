# Copy this file to .env and fill in your actual API keys.
# .env is git-ignored — never commit real keys.

# DeepSeek (decision-side LLM: Planner, Executor, Synthesizer, _compress_sub_goal)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DashScope (judge-side LLM: Auditor, memory_writer — vendor-independent from DeepSeek)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# SerpAPI (web search backend for RealWebEnv)
SERPAPI_KEY=your-serpapi-key-here

# OpenAI (optional, not used by default config but referenced for compatibility)
OPENAI_API_KEY=sk-your-openai-key-here
